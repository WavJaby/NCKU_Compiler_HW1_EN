10:15: NUMBER_LIT 1
10:18: NAME_IT name it
10:26: IDENT '乙'
11:5: FOR for
11:9: IDENT '試'
11:13: TIMES times
12:9: COMMENT NOTE
12:14: STR_LIT " 求其差謬：乙 = 甲平冪減二 "
13:9: EXP_MATH *
13:13: IDENT '甲'
13:17: <-
13:20: IDENT '甲'
13:25: EXP_MATH -
13:29: ITS its
13:33: ->
13:36: NUMBER_LIT 2
13:39: PAST prev
13:44: IDENT '乙'
13:48: TOPIC topic
13:54: SET set
13:58: ITS its
13:62: IS_THUS is thus
14:9: COMMENT NOTE
14:14: STR_LIT " 求其變率：丙 = 甲倍之 "
15:9: EXP_MATH *
15:13: NUMBER_LIT 2
15:15: <-
15:18: IDENT '甲'
15:23: NAME_IT name it
15:31: IDENT '丙'
16:9: COMMENT NOTE
16:14: STR_LIT " 茂 = 乙除以丙 "
17:9: EXP_MATH /
17:13: IDENT '乙'
17:17: ->
17:20: IDENT '丙'
17:25: NAME_IT name it
17:33: IDENT '茂'
18:9: COMMENT NOTE
18:14: STR_LIT " 依法損益：甲 = 甲減茂，以逼真值 "
19:9: EXP_MATH -
19:13: IDENT '甲'
19:17: ->
19:20: IDENT '茂'
19:25: NAME_IT name it
19:33: IDENT '甲'
20:5: END end
21:5: RETURN return
21:12: IDENT '甲'
22:1: FUNC_END_FOR func end for
22:14: IDENT '牛頓求根法'
22:22: FUNC_END func end
