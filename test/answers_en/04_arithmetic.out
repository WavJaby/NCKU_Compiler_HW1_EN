30:9: ->
30:12: NUMBER_LIT 1
30:15: PAST prev
30:20: IDENT '乙'
30:24: TOPIC topic
30:31: SET set
30:35: ITS its
30:39: IS_THUS is thus
30:74: COMMENT NOTE
30:79: STR_LIT " 乙 = 乙 - 1 "
31:1: HERE_ARE i have
31:8: NUMBER_LIT 2
31:10: VAR_TYPE str
31:15: SAID called
31:22: STR_LIT "乙損一籌，其數化為"
31:37: SAID called
31:44: IDENT '乙'
31:49: PRINT print
33:1: COMMENT NOTE
33:6: STR_LIT "連加運算與「其」之驗證"
34:1: EXP_MATH +
34:5: IDENT '甲'
34:9: <-
34:12: IDENT '乙'
34:17: NAME_IT name it
34:25: IDENT '丁'
34:62: COMMENT NOTE
34:67: STR_LIT " 丁 = 乙 + 甲 (11 + 2 = 13) "
35:1: EXP_MATH +
35:5: IDENT '丁'
35:9: <-
35:12: NUMBER_LIT 10
35:16: NAME_IT name it
35:24: IDENT '戊'
35:65: COMMENT NOTE
35:70: STR_LIT " 戊 = 10 + 丁 (10 + 13 = 23) "
36:1: EXP_MATH +
36:5: IDENT '甲'
36:9: <-
36:12: IDENT '乙'
36:17: EXP_MATH +
36:21: ITS its
36:25: <-
36:28: NUMBER_LIT 10
36:32: NAME_IT name it
36:40: IDENT '己'
36:67: COMMENT NOTE
36:72: STR_LIT " 己 = 10 + (乙 + 甲) (10 + 13 = 23) "
37:1: HERE_ARE i have
37:8: NUMBER_LIT 6
37:10: VAR_TYPE str
37:15: SAID called
37:22: STR_LIT "今以甲數"
37:32: SAID called
37:39: IDENT '甲'
38:5: SAID called
38:12: STR_LIT "，并乙復益十，步之得"
38:28: SAID called
38:35: IDENT '己'
39:5: SAID called
39:12: STR_LIT "，與戊同揆，皆為"
39:26: SAID called
39:33: IDENT '戊'
39:38: PRINT print
41:1: COMMENT NOTE
41:6: STR_LIT "一算訖即書之（算畢隨錄）"
42:1: HERE_ARE i have
42:8: NUMBER_LIT 2
42:10: VAR_TYPE str
42:15: SAID called
42:22: STR_LIT "并甲於乙，其數為"
42:36: SAID called
42:43: EXP_MATH +
42:47: IDENT '甲'
42:51: <-
42:54: IDENT '乙'
42:59: PRINT print
42:69: COMMENT NOTE
42:74: STR_LIT " printf("并甲於乙，其數為 %d\n", 乙 + 甲) "
43:1: HERE_ARE i have
43:8: NUMBER_LIT 2
43:10: VAR_TYPE str
43:15: SAID called
43:22: STR_LIT "乘甲以乙，其積為"
43:36: SAID called
43:43: EXP_MATH *
43:47: IDENT '甲'
43:51: ->
43:54: IDENT '乙'
43:59: PRINT print
43:69: COMMENT NOTE
43:74: STR_LIT " printf("乘甲以乙，其積為 %d\n", 甲 * 乙) "
